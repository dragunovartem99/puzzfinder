{
	"name": "puzzfinder",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vue-tsc -b && vite build",
		"dev": "vite",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint --fix",
		"lint:check": "oxlint",
		"prepare": "husky",
		"preview": "vite preview",
		"test": "vitest",
		"test:coverage": "vitest run --coverage",
		"types:check": "vue-tsc -b --noEmit"
	},
	"dependencies": {
		"@tanstack/vue-query": "^5.92.9",
		"html-diagram": "^0.5.8",
		"vue": "^3.5.29"
	},
	"devDependencies": {
		"@dragunovartem99/oxfmt-config": "^1.3.0",
		"@dragunovartem99/oxlint-config": "^1.0.0",
		"@tsconfig/node24": "^24.0.4",
		"@types/jsdom": "^28.0.0",
		"@types/node": "^24.11.0",
		"@vitejs/plugin-vue": "^6.0.4",
		"@vitest/coverage-v8": "^4.1.0",
		"@vue/test-utils": "^2.4.6",
		"@vue/tsconfig": "^0.8.1",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"npm-run-all2": "^8.0.4",
		"typescript": "~5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-vue-devtools": "^8.0.6",
		"vitest": "^4.0.18",
		"vue-tsc": "^3.2.5"
	},
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	}
}
